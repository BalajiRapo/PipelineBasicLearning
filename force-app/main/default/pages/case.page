<apex:page showHeader="true" sidebar="true" title="Case List" controller="CaseListController">
    <style>
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        th, td {
            border: 1px solid #ccc;
            padding: 8px;
            text-align: left;
        }

        th {
            background-color: #f2f2f2;
        }

        tr:nth-child(even) {
            background-color: #f2f2f2;
        }

        h1 {
            font-size: 24px;
        }
    </style>
    
    <h1>Case List</h1>
    <table>
        <tr>
            <th>Case Number</th>
            <th>Subject</th>
            <th>Status</th>
            <th>Created Date</th>
        </tr>
        <apex:repeat value="{!caseList}" var="caseItem">
            <tr>
                <td>{!caseItem.CaseNumber}</td>
                <td>{!caseItem.Subject}</td>
                <td>{!caseItem.Status}</td>
                <td>{!caseItem.CreatedDate}</td>
            </tr>
        </apex:repeat>
    </table>
</apex:page>